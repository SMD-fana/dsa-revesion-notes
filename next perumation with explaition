import java.util.*;

class Main {

    public void nextPermutation(int[] arr) {

        int n = arr.length;
        int index = -1;

        // Step 1: find breaking point
        for (int i = n - 2; i >= 0; i--) {
            if (arr[i] < arr[i + 1]) {
                index = i;
                break;
            }
        }

        // Step 2: if no breaking point → reverse whole array
        if (index == -1) {
            reverse(arr, 0, n - 1);
            return;
        }

        // Step 3: find just greater element
        for (int i = n - 1; i > index; i--) {
            if (arr[i] > arr[index]) {
                swap(arr, i, index);
                break;
            }
        }

        // Step 4: reverse right part
        reverse(arr, index + 1, n - 1);
    }

    // reverse function
    private void reverse(int[] arr, int start, int end) {
        while (start < end) {
            swap(arr, start, end);
            start++;
            end--;
        }
    }

    // swap function
    private void swap(int[] arr, int i, int j) {
        int temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
    }
}





